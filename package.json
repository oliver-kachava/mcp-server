{
  "name": "mcp-gateway",
  "version": "1.0.0",
  "description": "MCP gateway exposing downdetector-mcp, shopify-mcp, playwright-mcp over HTTP for Digital Ocean App Platform",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "downdetector-mcp": "^1.0.1",
    "shopify-mcp": "^1.0.7",
    "@playwright/mcp": "^0.0.68",
    "express": "^4.21.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "eslint": "^9.15.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
